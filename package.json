{
  "private": true,
  "type": "module",
  "version": "0.0.4",
  "author": "wnhlee <2wheeh@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/2wheeh/kaskaid"
  },
  "scripts": {
    "bump": "taze -r -w && pnpm install",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint",
    "prepare": "husky",
    "dev": "turbo run dev --filter=demo",
    "build": "turbo run build --filter=demo",
    "check-types": "turbo run check-types",
    "test": "turbo run test --filter=kaskaid",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "release": "turbo run build --filter=kaskaid && changeset publish",
    "docs:dev": "turbo run dev --filter=docs",
    "docs:build": "turbo run build --filter=docs",
    "docs:preview": "turbo run preview --filter=docs",
    "example:dev": "turbo run dev --filter=tanstack-start-example"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxlint": "^1.39.0",
    "prettier": "^3.7.4",
    "taze": "^19.9.2",
    "turbo": "^2.7.3"
  }
}
