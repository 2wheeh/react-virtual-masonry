{
  "name": "kaskaid",
  "type": "module",
  "version": "0.6.0",
  "description": "Virtualized masonry layout for React, powered by @tanstack/virtual.",
  "keywords": [
    "masonry",
    "masonry-layout",
    "virtual",
    "virtualized",
    "virtualization",
    "windowing",
    "react",
    "pinterest",
    "layout",
    "grid",
    "cascade",
    "tanstack"
  ],
  "author": "wnhlee <2wheeh@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/2wheeh/kaskaid.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "check-types": "tsc",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react-compiler-runtime": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-babel": "^6.1.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "babel-plugin-react-compiler": "^1.0.0",
    "happy-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "0.19.0-beta.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-virtual": ">=3.13.24",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
